# Ignore everything by default
*

# Track .gitignore itself
!.gitignore

# Track manifest and lock (committed for reproducible installs)
!agents.toml
!agents.lock
!config.toml
!models.toml

# Track fs/ and work/
!fs/
!fs/**
!work/
!work/**
# Added by Meridian to keep required project state tracked
!work-archive/
!work-archive/**
